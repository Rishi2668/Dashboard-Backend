# Local PostgreSQL (install from postgresql.org — no Docker):
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/ssc_cgl_db
# Neon / Supabase (replace with your connection string, use postgresql+asyncpg://):
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/ssc_cgl_db
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
REDIS_URL=redis://localhost:6379/0
GEMINI_API_KEY=
OPENROUTER_API_KEY=
AI_PROVIDER=rule_based
EXAM_DATE=2026-06-15
